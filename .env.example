# =============================================================================
# subenum — environment variables
# =============================================================================
# Copy this file to .env and fill in the keys you have.
# Keys that are left blank are silently skipped — the tool still works with
# the 8 free sources that require no authentication.
#
#   cp .env.example .env
#
# Never commit your .env file. It is already in .gitignore.
# =============================================================================


# -----------------------------------------------------------------------------
# PASSIVE SOURCES
# -----------------------------------------------------------------------------

# VirusTotal
# Free API key (4 req/min) — https://www.virustotal.com/gui/sign-in
# Enables: virustotal source (subdomain enumeration via VT graph)
VT_API_KEY=

# urlscan.io
# Free API key — https://urlscan.io/user/signup
# Enables: urlscan source (subdomains from scan results)
URLSCAN_API_KEY=

# ProjectDiscovery Chaos
# Free API key — https://chaos.projectdiscovery.io
# One of the largest public subdomain datasets available; updated regularly.
# Enables: chaos source
CHAOS_API_KEY=

# GitHub Personal Access Token
# Optional — without it GitHub Search API is limited to 10 req/min (vs 30 authenticated)
# Create at: https://github.com/settings/tokens (no scopes needed for public search)
# Enables: github source (subdomain discovery in public code)
GITHUB_TOKEN=


# -----------------------------------------------------------------------------
# ENRICHMENT
# -----------------------------------------------------------------------------

# Shodan
# Paid plan required for full host data; free account gets limited API credits
# https://account.shodan.io/
# Enables: --shodan flag (open ports, banners, CVEs per resolved IP)
SHODAN_API_KEY=


# -----------------------------------------------------------------------------
# NOTIFICATIONS
# -----------------------------------------------------------------------------

# Webhook URL for scan notifications (Discord, Slack, or generic JSON endpoint)
#
# Discord:  https://discord.com/api/webhooks/<id>/<token>
# Slack:    https://hooks.slack.com/services/<T>/<B>/<token>
# Generic:  any URL that accepts a POST with JSON body {"title": "...", "body": "..."}
#
# Alerts are sent at the end of each scan and include: total subdomains,
# resolved/live counts, takeover candidates, new subs (--diff), high-value tech.
WEBHOOK_URL=
